{
  "name": "signal-lynx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "postbuild": "node scripts/vercel-postbuild-trim.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "npm run check -- --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/client-sesv2": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "fuse.js": "^7.1.0",
    "handlebars": "^4.7.9",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.19.17",
    "daisyui": "^5.5.19",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "cookie": "^1.1.1",
    "devalue": "^5.6.4",
    "tar": "^7.5.11",
    "fast-xml-parser": "5.5.7",
    "flatted": "3.4.2",
    "qs": "^6.15.0",
    "minimatch": "^10.2.4"
  }
}
